{
  "$defs": {
    "ApplicationSettings": {
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": [
            "uptime-kuma",
            "technitium"
          ],
          "title": "Type",
          "type": "string"
        },
        "guest": {
          "title": "Guest",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "port": {
          "default": 3001,
          "maximum": 65535,
          "minimum": 1024,
          "title": "Port",
          "type": "integer"
        },
        "credential": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Credential"
        }
      },
      "required": [
        "type",
        "guest"
      ],
      "title": "ApplicationSettings",
      "type": "object"
    },
    "AutomationSettings": {
      "additionalProperties": false,
      "properties": {
        "ssh_user": {
          "default": "automation",
          "title": "Ssh User",
          "type": "string"
        },
        "ssh_private_key": {
          "default": "~/.ssh/homelab_ed25519",
          "title": "Ssh Private Key",
          "type": "string"
        },
        "ssh_public_keys": {
          "items": {
            "type": "string"
          },
          "maxItems": 10,
          "title": "Ssh Public Keys",
          "type": "array"
        },
        "ssh_public_key_files": {
          "items": {
            "type": "string"
          },
          "maxItems": 10,
          "title": "Ssh Public Key Files",
          "type": "array"
        },
        "become": {
          "default": true,
          "title": "Become",
          "type": "boolean"
        }
      },
      "title": "AutomationSettings",
      "type": "object"
    },
    "CloudflareDnsRecord": {
      "additionalProperties": false,
      "description": "One public DNS record exclusively owned by OpenTofu.",
      "properties": {
        "zone": {
          "title": "Zone",
          "type": "string"
        },
        "name": {
          "description": "Relative record name, or @ for the zone apex",
          "title": "Name",
          "type": "string"
        },
        "type": {
          "enum": [
            "A",
            "AAAA",
            "CNAME"
          ],
          "title": "Type",
          "type": "string"
        },
        "content": {
          "title": "Content",
          "type": "string"
        },
        "ttl": {
          "default": 1,
          "title": "Ttl",
          "type": "integer"
        },
        "proxied": {
          "default": false,
          "title": "Proxied",
          "type": "boolean"
        }
      },
      "required": [
        "zone",
        "name",
        "type",
        "content"
      ],
      "title": "CloudflareDnsRecord",
      "type": "object"
    },
    "CloudflareSettings": {
      "additionalProperties": false,
      "properties": {
        "domains": {
          "description": "Public DNS domains managed through Cloudflare",
          "items": {
            "type": "string"
          },
          "maxItems": 20,
          "title": "Domains",
          "type": "array"
        },
        "records": {
          "items": {
            "$ref": "#/$defs/CloudflareDnsRecord"
          },
          "maxItems": 500,
          "title": "Records",
          "type": "array"
        }
      },
      "title": "CloudflareSettings",
      "type": "object"
    },
    "DeploymentSettings": {
      "additionalProperties": false,
      "properties": {
        "channel": {
          "default": "stable",
          "enum": [
            "stable",
            "edge"
          ],
          "title": "Channel",
          "type": "string"
        },
        "check_interval_minutes": {
          "default": 60,
          "maximum": 10080,
          "minimum": 5,
          "title": "Check Interval Minutes",
          "type": "integer"
        },
        "automatic_updates": {
          "default": false,
          "title": "Automatic Updates",
          "type": "boolean"
        },
        "require_confirmation": {
          "default": true,
          "title": "Require Confirmation",
          "type": "boolean"
        }
      },
      "title": "DeploymentSettings",
      "type": "object"
    },
    "NetworkSettings": {
      "additionalProperties": false,
      "properties": {
        "management_cidr": {
          "default": "192.168.10.0/24",
          "format": "ipvanynetwork",
          "title": "Management Cidr",
          "type": "string"
        },
        "gateway": {
          "default": "192.168.10.1",
          "format": "ipvanyaddress",
          "title": "Gateway",
          "type": "string"
        },
        "dns_servers": {
          "items": {
            "format": "ipvanyaddress",
            "type": "string"
          },
          "maxItems": 4,
          "minItems": 1,
          "title": "Dns Servers",
          "type": "array"
        },
        "bridge": {
          "default": "vmbr0",
          "maxLength": 15,
          "minLength": 1,
          "title": "Bridge",
          "type": "string"
        },
        "vlan_id": {
          "anyOf": [
            {
              "maximum": 4094,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vlan Id"
        }
      },
      "title": "NetworkSettings",
      "type": "object"
    },
    "ProxmoxLxcSettings": {
      "additionalProperties": false,
      "description": "One OpenTofu-owned, unprivileged Debian LXC guest.",
      "properties": {
        "key": {
          "description": "Stable resource key that survives list reordering",
          "title": "Key",
          "type": "string"
        },
        "vm_id": {
          "maximum": 999999999,
          "minimum": 100,
          "title": "Vm Id",
          "type": "integer"
        },
        "hostname": {
          "title": "Hostname",
          "type": "string"
        },
        "template_file_id": {
          "description": "Proxmox template ID such as local:vztmpl/x.tar.zst",
          "title": "Template File Id",
          "type": "string"
        },
        "address": {
          "format": "ipv4interface",
          "title": "Address",
          "type": "string"
        },
        "cores": {
          "default": 1,
          "maximum": 128,
          "minimum": 1,
          "title": "Cores",
          "type": "integer"
        },
        "memory_mb": {
          "default": 1024,
          "maximum": 1048576,
          "minimum": 256,
          "title": "Memory Mb",
          "type": "integer"
        },
        "swap_mb": {
          "default": 512,
          "maximum": 1048576,
          "minimum": 0,
          "title": "Swap Mb",
          "type": "integer"
        },
        "disk_gb": {
          "default": 8,
          "maximum": 16384,
          "minimum": 1,
          "title": "Disk Gb",
          "type": "integer"
        },
        "started": {
          "default": true,
          "title": "Started",
          "type": "boolean"
        },
        "start_on_boot": {
          "default": true,
          "title": "Start On Boot",
          "type": "boolean"
        },
        "nesting": {
          "default": false,
          "title": "Nesting",
          "type": "boolean"
        },
        "protection": {
          "default": false,
          "title": "Protection",
          "type": "boolean"
        },
        "tags": {
          "items": {
            "type": "string"
          },
          "maxItems": 20,
          "title": "Tags",
          "type": "array"
        }
      },
      "required": [
        "key",
        "vm_id",
        "hostname",
        "template_file_id",
        "address"
      ],
      "title": "ProxmoxLxcSettings",
      "type": "object"
    },
    "ProxmoxSettings": {
      "additionalProperties": false,
      "properties": {
        "api_url": {
          "default": "https://pve.home.arpa:8006",
          "format": "uri",
          "minLength": 1,
          "title": "Api Url",
          "type": "string"
        },
        "node": {
          "default": "pve",
          "maxLength": 63,
          "minLength": 1,
          "title": "Node",
          "type": "string"
        },
        "storage": {
          "default": "local-lvm",
          "maxLength": 63,
          "minLength": 1,
          "title": "Storage",
          "type": "string"
        },
        "token_id": {
          "default": "homelab@pve!control-plane",
          "description": "Proxmox API token identifier; the secret is supplied separately",
          "title": "Token Id",
          "type": "string"
        },
        "verify_tls": {
          "default": true,
          "title": "Verify Tls",
          "type": "boolean"
        },
        "containers": {
          "items": {
            "$ref": "#/$defs/ProxmoxLxcSettings"
          },
          "maxItems": 100,
          "title": "Containers",
          "type": "array"
        }
      },
      "title": "ProxmoxSettings",
      "type": "object"
    },
    "SiteSettings": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "default": "homelab",
          "description": "Short identifier for this homelab",
          "title": "Name",
          "type": "string"
        },
        "domain": {
          "default": "home.arpa",
          "description": "Internal DNS domain",
          "title": "Domain",
          "type": "string"
        },
        "timezone": {
          "default": "Pacific/Auckland",
          "description": "IANA timezone",
          "title": "Timezone",
          "type": "string"
        },
        "environment": {
          "default": "production",
          "enum": [
            "development",
            "staging",
            "production"
          ],
          "title": "Environment",
          "type": "string"
        }
      },
      "title": "SiteSettings",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Top-level, versioned configuration for one homelab site.",
  "properties": {
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "site": {
      "$ref": "#/$defs/SiteSettings"
    },
    "cloudflare": {
      "$ref": "#/$defs/CloudflareSettings"
    },
    "proxmox": {
      "$ref": "#/$defs/ProxmoxSettings"
    },
    "network": {
      "$ref": "#/$defs/NetworkSettings"
    },
    "automation": {
      "$ref": "#/$defs/AutomationSettings"
    },
    "deployment": {
      "$ref": "#/$defs/DeploymentSettings"
    },
    "applications": {
      "additionalProperties": {
        "$ref": "#/$defs/ApplicationSettings"
      },
      "maxProperties": 20,
      "title": "Applications",
      "type": "object"
    }
  },
  "title": "HomelabConfig",
  "type": "object"
}
